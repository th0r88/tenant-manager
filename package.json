{
  "name": "tenant-manager",
  "version": "1.5.5",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node src/backend/server.js",
    "client": "vite --port 3000",
    "build": "vite build",
    "preview": "vite preview src/frontend",
    "clean": "rm -rf dist node_modules package-lock.json",
    "reset": "npm run clean && npm install",
    "check": "npm run build && npm run server & sleep 3 && curl -f http://localhost:5999/api/health && pkill -f 'node.*server.js'",
    "validate-translations": "node scripts/validateTranslations.js",
    "test": "vitest",
    "test:backend": "vitest run --config src/backend/tests/vitest.config.js",
    "test:unit": "vitest run --config src/backend/tests/vitest.config.js src/backend/tests/unit/",
    "test:localization": "vitest run src/frontend/tests/localization.test.jsx",
    "test:pdf-language": "vitest run src/backend/tests/pdfLanguage.test.js",
    "backup": "node src/backend/utils/backupCli.js backup",
    "backup:restore": "node src/backend/utils/backupCli.js restore",
    "recalculate-allocations": "node scripts/recalculate-utility-allocations.js",
    "verify-allocations": "node scripts/verify-allocations.js",
    "backup:list": "node src/backend/utils/backupCli.js list",
    "backup:verify": "node src/backend/utils/backupCli.js verify",
    "backup:info": "node src/backend/utils/backupCli.js info",
    "backup:cleanup": "node src/backend/utils/backupCli.js cleanup"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "archiver": "^7.0.1",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "daisyui": "^5.0.43",
    "decimal.js": "^10.5.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "react-i18next": "^17.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  }
}
